// ============================================================
// Control de Asistencia NOM-037 — Schema v2.2 (PostgreSQL)
// ============================================================
// ESTE ARCHIVO ES PARA PRODUCCIÓN (Vercel + Supabase).
// Para desarrollo local, usar `schema.prisma` (SQLite).
//
// Cambiar entre los dos con:
//   ./scripts/switch-schema.sh postgres   ← producción
//   ./scripts/switch-schema.sh sqlite     ← dev local
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

// ============================================================
// MODELO: Company (singleton) — datos de la empresa
// ============================================================

model Company {
  id                 String   @id @default("singleton")
  razonSocial        String
  rfc                String
  registroPatronal   String?
  domicilioFiscal    String?
  telefono           String?
  email              String?
  logoUrl            String?
  representanteLegal String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ============================================================
// MODELO: User
// ============================================================

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String
  role                String   @default("EMPLOYEE") // GENERAL_ADMIN | SUCURSAL_ADMIN | SUPERVISOR | EMPLOYEE
  sucursalId          String?
  isActive            Boolean  @default(true)
  lastLoginAt         DateTime?
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  // --- MFA (Phase A — NextAuth + TOTP) ---
  mfaEnabled          Boolean  @default(false)
  mfaSecret           String?  // TOTP secret (encrypted at rest via app-level AES)
  mfaBackupCodesHash  String?  // JSON array of bcrypt hashes
  mfaEnrolledAt       DateTime?
  // --- LFPDPPP — Consentimiento del Aviso de Privacidad ---
  // privacyAcceptedAt: fecha en que el usuario aceptó el aviso de privacidad.
  // privacyAcceptedVersion: versión del aviso aceptada (ej. "1.0").
  // privacyAcceptedIp: IP desde la cual aceptó (evidencia para auditoría INAI).
  // Si privacyAcceptedAt es NULL → el middleware redirige a /legal/aviso-de-privacidad.
  // Si privacyAcceptedVersion != CURRENT_PRIVACY_VERSION → se vuelve a pedir consentimiento.
  privacyAcceptedAt        DateTime?
  privacyAcceptedVersion   String?
  privacyAcceptedIp        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  employee                Employee?
  auditLogs               AuditLog[]
  sucursal                Sucursal?            @relation("SucursalAdmins", fields: [sucursalId], references: [id])
  vacationsRequested      Vacation[]           @relation("VacationRequester")
  vacationsApproved       Vacation[]           @relation("VacationApprover")
  justificationsResolved  AttendanceRecord[]  @relation("JustificationResolver")
  attendanceCorrections   AttendanceRecord[]  @relation("AttendanceCorrector")
  dynamicQRs              DynamicQR[]          @relation("DynamicQRCreator")
  privacyRequests         PrivacyRequest[]    @relation("PrivacyRequester")
  privacyResolved         PrivacyRequest[]    @relation("PrivacyRequestResolver")

  @@index([sucursalId])
  @@index([role])
  @@index([privacyAcceptedAt])
}

// ============================================================
// MODELO: PrivacyRequest — Derechos ARCO (LFPDPPP art. 29-32)
// ============================================================
// Solicitudes formales que el titular (empleado) hace al responsable
// (la empresa) para ejercer sus derechos:
//   ACCESS         — Conocer qué datos personales se tienen (art. 29).
//   RECTIFICATION  — Corregir datos inexactos (art. 30).
//   CANCELLATION   — Solicitar supresión / "derecho al olvido" (art. 31).
//                    ⚠️ CONFLICTO LEGISLATIVO: LFPDPPP art. 31 ordena suprimir,
//                    pero LFT art. 804 obliga a conservar registros de asistencia
//                    por 12 meses. Decisión de diseño: se anonimiza (se
//                    reemplazan identificadores por hashes irreversibles) y se
//                    conserva el registro probatorio sin identidad.
//   OPPOSITION     — Oponerse al tratamiento para ciertas finalidades (art. 32).
// ============================================================

model PrivacyRequest {
  id              String   @id @default(cuid())
  userId          String
  type            String   // ACCESS | RECTIFICATION | CANCELLATION | OPPOSITION
  status          String   @default("PENDING") // PENDING | IN_PROGRESS | RESOLVED | REJECTED
  requestDetails  String?  // JSON: { fields?: string[], reason?: string, targetData?: string }
  resolutionNotes String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
  resolvedById    String?

  user          User     @relation("PrivacyRequester", fields: [userId], references: [id])
  resolvedBy    User?    @relation("PrivacyRequestResolver", fields: [resolvedById], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// ============================================================
// MODELO: Sucursal
// ============================================================

model Sucursal {
  id                       String   @id @default(cuid())
  name                     String   @unique
  codigoLocal              String?  // "261" para Matriz
  address                  String
  latitude                 Float?
  longitude                Float?
  geofenceRadiusMeters     Int      @default(150)
  enforceGeofence          Boolean  @default(false)
  mealToleranceMinutes     Int      @default(5)
  restToleranceMinutes     Int      @default(3)
  mealDurationMinutes      Int      @default(30)
  restDurationMinutes      Int      @default(15)
  checkoutToleranceMinutes Int      @default(10)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  employees         Employee[]
  admins            User[]              @relation("SucursalAdmins")
  attendanceRecords AttendanceRecord[]
}

// ============================================================
// MODELO: Employee
// ============================================================

model Employee {
  id                  String   @id @default(cuid())
  employeeNumber      String   @unique
  position            String
  department          String
  sucursalId          String
  userId              String   @unique
  hireDate            DateTime @default(now())
  baseSalary          Float?
  vacationBalanceDays Int      @default(12)
  // --- RFC y CURP (identificadores fiscales y de identidad, art. 804 LFT) ---
  // RFC: Registro Federal de Contribuyentes (emite el SAT), 12-13 caracteres.
  // CURP: Clave Única de Registro de Población (emite el RENAPO), 18 caracteres.
  // Son OPCIONALES para no forzar la captura en empleados existentes que aún
  // no los tienen. Son ÚNICOS porque RFC y CURP no se reparten entre personas
  // físicas. Se guardan tal cual los captura el admin (mayúsculas normalmente),
  // sin normalización automática (trim/lowercase).
  rfc                 String?  @unique
  curp                String?  @unique
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id])
  sucursal         Sucursal         @relation(fields: [sucursalId], references: [id])
  workSchedules    WorkSchedule[]
  attendanceRecords AttendanceRecord[]
  vacations        Vacation[]

  @@index([sucursalId])
  @@index([isActive])
}

// ============================================================
// MODELO: WorkSchedule
// ============================================================

model WorkSchedule {
  id               String  @id @default(cuid())
  employeeId       String
  dayOfWeek        Int     // 0=domingo ... 6=sábado
  startTime        String  // "HH:mm"
  endTime          String  // "HH:mm"
  toleranceMinutes Int     @default(10)
  isWeeklyRest     Boolean @default(false)
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
}

// ============================================================
// MODELO: AttendanceRecord (INMUTABLE — NOM-037)
// ============================================================

model AttendanceRecord {
  id                        String   @id @default(cuid())
  employeeId                String
  sucursalId                String
  date                      DateTime
  checkInTime               DateTime?
  checkInLat                Float?
  checkInLong               Float?
  checkInMethod             String?
  checkInIp                 String?
  checkInUserAgent          String?
  checkOutTime              DateTime?
  checkOutLat               Float?
  checkOutLong              Float?
  checkOutMethod            String?
  checkOutIp                String?
  checkOutUserAgent         String?
  mealStart                 DateTime?
  mealEnd                   DateTime?
  mealDurationMinutes       Int?
  mealExceeded              Boolean  @default(false)
  restStart                 DateTime?
  restEnd                   DateTime?
  restDurationMinutes       Int?
  restExceeded              Boolean  @default(false)
  status                    String   @default("PRESENT") // PRESENT|ABSENT|LATE|EARLY_LEAVE
  workedMinutes             Int?
  overtimeMinutes           Int?     // total de minutos extra (legacy/agregado)
  // --- Reforma LFT 2027 (art. 66 y 68) — distinguir dobles vs triples ---
  // Primeras 9h/semana (2027) → doble. Excedente → triple. Tope diario: 4h.
  overtimeDoubleMinutes     Int?     // minutos extra pagados al DOBLE (art. 66)
  overtimeTripleMinutes     Int?     // minutos extra pagados al TRIPLE (art. 68, excedente semanal)
  overtimeWeeklyAccumulated Int?     // acumulado semanal previo al registro (para tope)
  // --- Prima por descanso trabajado (art. 73 LFT) ---
  // Si el empleado labora en su día de descanso semanal, se paga con prima del 100%
  // (salario doble por el día completo). No se considera overtime (art. 66/68).
  isRestDayWorked           Boolean  @default(false) // true si la fecha del registro es día de descanso del empleado
  restDayWorkedMinutes      Int?     // minutos trabajados en día de descanso (jornada completa, no overtime)
  restDayPremiumMinutes     Int?     // prima del 100% adicional (art. 73 LFT) = restDayWorkedMinutes
  isSunday                  Boolean  @default(false) // true si la fecha cae en domingo (para prima dominical art. 71)
  // --- Jornada nocturna / mixta (art. 60 y 61 LFT) ---
  // Clasificación automática al check-out según los minutos trabajados en
  // horario nocturno (20:00-06:00). Para nómina: si es NOCTURNA o MIXTA,
  // aplica prima nocturna del 25% sobre las horas diurnas (art. 61 + jurisprudencia).
  shiftType                  String?  // "DIURNA" | "NOCTURNA" | "MIXTA" (art. 60 LFT)
  nightMinutes               Int?     // minutos trabajados en horario nocturno (20:00-06:00)
  notes                     String?
  justification             String?
  justificationStatus       String?  // PENDING / APPROVED / REJECTED
  justificationResolvedById String?
  // --- Inmutabilidad (reforma LFT art. 132 XXXIV — trazabilidad probatoria) ---
  isLocked                  Boolean  @default(true)
  originalCheckInTime       DateTime? // valor original no sobreescribible
  originalCheckOutTime      DateTime? // valor original no sobreescribible
  correctionReason          String?   // motivo de la corrección (si isLocked=false)
  correctedById             String?   // quién corrigió
  correctedAt               DateTime? // cuándo corrigió
  // --- Prueba plena (art. 132 XXXIV: "hará prueba plena si fue acordado") ---
  employeeSignedAt          DateTime? // fecha en que el empleado aceptó el registro
  employeeSignatureHash     String?   // hash del contenido firmado (HMAC)
  employeeSignedIp          String?   // IP desde la que firmó
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  employee            Employee @relation(fields: [employeeId], references: [id])
  sucursal            Sucursal @relation(fields: [sucursalId], references: [id])
  justificationResolver User?  @relation("JustificationResolver", fields: [justificationResolvedById], references: [id])
  correctedBy         User?    @relation("AttendanceCorrector", fields: [correctedById], references: [id])

  @@unique([employeeId, date])
  @@index([sucursalId, date])
  @@index([date])
  @@index([status])
}

// ============================================================
// MODELO: Vacation
// ============================================================

model Vacation {
  id              String   @id @default(cuid())
  employeeId      String
  type            String   @default("VACACIONES") // VACACIONES|PERMISO|INCAPACIDAD|MATERNIDAD|PATERNIDAD|OTRO
  startDate       DateTime
  endDate         DateTime
  days            Int
  reason          String?
  status          String   @default("PENDING") // PENDING|APPROVED|REJECTED|CANCELLED
  requestedById   String
  approvedById    String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // --- Nuevos campos: permisos parciales y otorgamiento directo por admin ---
  // grantMode: EMPLOYEE_REQUEST (solicitud del empleado, queda PENDING)
  //            ADMIN_GRANTED     (otorgado directamente por admin, nace APPROVED)
  grantMode       String   @default("EMPLOYEE_REQUEST")
  // isPartial: true = permiso por horas dentro de un día (no descuenta saldo).
  isPartial       Boolean  @default(false)
  startTime       DateTime? // hora de salida (permiso parcial)
  endTime         DateTime? // hora de regreso opcional (permiso parcial)
  partialHours    Int?      // duración en horas (calculada o ingresada)

  employee    Employee @relation(fields: [employeeId], references: [id])
  requestedBy User     @relation("VacationRequester", fields: [requestedById], references: [id])
  approvedBy  User?    @relation("VacationApprover", fields: [approvedById], references: [id])

  @@index([employeeId, startDate])
  @@index([status])
  @@index([startDate, endDate])
}

// ============================================================
// MODELO: Holiday — días feriados
// ============================================================

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @unique
  name        String
  description String?
  isOfficial  Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ============================================================
// MODELO: AuditLog
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  sucursalId String?
  ipAddress  String?
  userAgent  String?
  details    String?  // JSON string
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sucursalId])
  @@index([createdAt])
  @@index([action])
}

// ============================================================
// MODELO: DynamicQR
// ============================================================

model DynamicQR {
  id          String   @id @default(cuid())
  code        String   @unique
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("DynamicQRCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}
