# ============================================================
# Control de Asistencia NOM-037 v2.2 — Variables de Entorno
# ============================================================
# Copy this file to .env and fill in your values.
# For Vercel deployment, add these in Settings > Environment Variables.
# ============================================================

# --- DATABASE ---
# Local development (SQLite):
# DATABASE_URL=file:./db/custom.db
#
# Production (Supabase PostgreSQL — get from Supabase Dashboard > Settings > Database > Connection string):
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- AUTH ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-to-a-random-32-byte-secret
NEXTAUTH_URL=http://localhost:3000

# --- QR HMAC SECRET ---
# Generate with: openssl rand -base64 32
QR_HMAC_SECRET=change-this-to-another-random-secret

# --- RATE LIMITING (optional, recommended for production) ---
# Get from: https://console.upstash.com/ (create a Redis database)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- OBSERVABILITY (optional) ---
SENTRY_DSN=

# --- NODE ENV ---
NODE_ENV=development
