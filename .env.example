# ============================================================
# Control de Asistencia NOM-037 — Variables de Entorno
# ============================================================
# Copia este archivo a .env para desarrollo local, o configura
# estas variables en Vercel Dashboard > Settings > Environment Variables.
#
# En Vercel NO necesitas .env, configura todo vía el dashboard.
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS (Supabase PostgreSQL)
# ------------------------------------------------------------
# Encontrar en: Supabase Dashboard > Project Settings > Database
# Connection string (transaction pooler - recomendado para serverless):
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Connection string (session mode - para migraciones Prisma):
DIRECT_URL="postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------
# NEXTAUTH (Autenticación JWT firmado)
# ------------------------------------------------------------
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-generado-con-openssl-rand-base64-32"
# URL donde corre la app:
# - Dev local:    http://localhost:3000
# - Vercel prod:  https://tu-proyecto.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------
# SERVICIO REALTIME (Socket.io en Railway/Render)
# ------------------------------------------------------------
# URL pública del mini-service realtime desplegado en Railway/Render.
# En el sandbox NO se configura (usa gateway Caddy automáticamente).
# En Vercel SÍ se debe configurar con la URL de Railway:
# - Backend (server-to-server):  https://tu-realtime.up.railway.app
REALTIME_SERVICE_URL="http://localhost:3003"
# - Frontend (client browser, NEXT_PUBLIC_*): misma URL pero es pública
NEXT_PUBLIC_REALTIME_URL=""

# ------------------------------------------------------------
# CORS del servicio realtime
# ------------------------------------------------------------
# Origen permitido para conexiones Socket.io desde el navegador.
# En prod: la URL de tu app en Vercel (sin slash final).
# Esta variable se setea en Railway/Render, NO en Vercel.
CORS_ORIGIN="https://tu-proyecto.vercel.app"

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NODE_ENV="development"
# TZ automática para México (NOM-037 exige horario local)
# Solo informativo — la app usa getMexicoNow() internamente
TZ="America/Mexico_City"

# ------------------------------------------------------------
# OPCIONAL: Rate limiting con Upstash Redis
# ------------------------------------------------------------
# Solo si quieres rate limiting en endpoints sensibles (login, etc.)
# Si no se configuran, el rate limiting es en memoria (por instancia).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ============================================================
# NOTAS PARA VERCEL
# ============================================================
# 1. Solo configura estas vars en Vercel (Dashboard > Settings > Env Vars):
#    - DATABASE_URL       (Supabase pooler)
#    - DIRECT_URL         (Supabase directa)
#    - NEXTAUTH_SECRET    (generar nuevo, diferente al de dev)
#    - NEXTAUTH_URL       (URL de Vercel: https://xxx.vercel.app)
#    - REALTIME_SERVICE_URL (URL de Railway: https://xxx.up.railway.app)
#    - NEXT_PUBLIC_REALTIME_URL (misma que REALTIME_SERVICE_URL)
#
# 2. NO configurar en Vercel:
#    - CORS_ORIGIN    (va en Railway, no en Vercel)
#    - TZ             (Vercel usa UTC por defecto, la app maneja MX)
#
# 3. El schema se cambia a PostgreSQL automáticamente en el build de Vercel
#    (ver vercel.json buildCommand). NO necesitas correr switch-schema.sh para deploy.
#    El primer deploy crea las tablas y carga el seed automáticamente (idempotente).
# ============================================================
