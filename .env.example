# ============================================================
# Control de Asistencia - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# For Vercel deployment, add these in Settings > Environment Variables
# ============================================================

# --- LOCAL DEVELOPMENT (SQLite) ---
DATABASE_URL=file:./db/custom.db

# --- SUPABASE (Required for Vercel deployment) ---
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API
#
# 1. Project URL (found in Project Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# 2. anon/public key (found in Project Settings > API > Project API keys > anon public)
#    This is a JWT token starting with "eyJ..."
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# 3. service_role key (found in Project Settings > API > Project API keys > service_role secret)
#    This is a JWT token starting with "eyJ..."
#    ⚠️ KEEP THIS SECRET - never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- OPTIONAL: Direct PostgreSQL connection (for migrations) ---
# Database password from: https://supabase.com/dashboard > Your Project > Settings > Database
# SUPABASE_DB_PASSWORD=your-database-password
# DIRECT_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
